# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Privy (auth + wallets) - https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# Pinata (IPFS)
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# Optional: App URL for server-side fetch (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=

# Document encryption (generate a random 32-byte hex for production)
DOC_ENCRYPTION_SECRET=your-32-byte-hex-secret-here
