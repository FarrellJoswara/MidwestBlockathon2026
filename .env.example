# Will registry (on-chain) — deploy from lib/contract-generator, then set:
NEXT_PUBLIC_WILL_REGISTRY_ADDRESS=
# Optional: RPC for chain reads (defaults to XRPL EVM testnet)
# WILL_REGISTRY_RPC_URL=https://rpc.testnet.xrplevm.org

# Privy (auth + wallets) - https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# Pinata (IPFS)
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# Optional: App URL for server-side fetch (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=

# Document encryption (generate a random 32-byte hex for production)
DOC_ENCRYPTION_SECRET=your-32-byte-hex-secret-here

# Google Gemini API (will parsing, server-only)
GEMINI_API_KEY=

# Client-side contract generate (demo only — key is exposed to browser)
# Set this for the create-will flow to generate Solidity in the browser; optional if using server generate-and-deploy.
NEXT_PUBLIC_GEMINI_API_KEY=
